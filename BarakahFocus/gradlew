##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       command line, like:
#
#           ksh gradlew
#
#       Busybox and similar reduced shells will NOT work, because this script
#       requires all of these POSIX shell features:
#         * functions;
#         * expansions `${var## */}`;
#         * signal trapping (trap).
#
##############################################################################

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$(uname)" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD="java"
    which java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
fi

# Increase the maximum file descriptors if we can.
if ! $darwin && ! $nonstop ; then
    # No lsof, disable, but let the user override with MAX_FD.
    if command -v lsof >/dev/null 2>&1; then
        MAX_FD=$(lsof -p $$ -Fn0 | grep '^F' | awk '{print $2}' | sort -un | head -1)
        if [ -z "$MAX_FD" ] || [ "$MAX_FD" -eq 0 ]; then
            MAX_FD=1024
        fi
    fi
fi

# Collect all arguments for the java command, stacking in reverse order to preserve original argument order.
eval set -- "$DEFAULT_JVM_OPTS" "$JAVA_OPTS" "$GRADLE_OPTS" "$@"

# For Darwin, add frameworks classpath.
if $darwin; then
    GRADLE_OPTS="$GRADLE_OPTS -XstartOnFirstThread"
fi

# Stop when "xargs" is not available.
if ! command -v xargs >/dev/null 2>&1; then
    die "xargs is not available"
fi

# Use "xargs" to parse quoted args.
# The parser will generate one execution per arg, with a newline as the arg separator.
# The wrapper script will parse the output and add the args to the java command.
# The parsing is necessary because we might have multiple args in one line (e.g. -Dfoo=bar), and
# the arg must be passed as a single argument to the java command.
args="$@"
printf '%s\n' "$args" | while IFS= read -r arg; do
    # Remove surrounding quotes
    arg=$(eval echo "$arg")
    # Split on spaces if the argument is not quoted
    case "$arg" in
        * * )
            # The argument contains spaces, but we don't know if it's quoted or not.
            # We'll just pass it through as is, trusting the user knows what they're doing.
            echo "$arg"
            ;;
        * )
            # No spaces, safe to split.
            echo "$arg" | tr ' ' '\n'
            ;;
    esac
done | while IFS= read -r arg; do
    # Trim whitespace
    arg=$(echo "$arg" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ -n "$arg" ]; then
        args_final="$args_final "$arg""
    fi
done
eval set -- "$args_final"

# Collect all arguments
while [ "$#" -gt 0 ]; do
    arg="$1"
    case "$arg" in
        -D*)
            JAVA_OPTS="$JAVA_OPTS "$arg""
            ;;
        *)
            ARGS="$ARGS "$arg""
            ;;
    esac
    shift
done

# Execute the Java command
exec "$JAVACMD" $JAVA_OPTS $GRADLE_OPTS -cp "$CLASSPATH" org.gradle.wrapper.GradleWrapperMain $ARGS
